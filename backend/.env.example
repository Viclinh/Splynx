# ── Splunk Connection ──────────────────────────────────────────────────────────
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
# Recommended: use token auth instead of username/password
SPLUNK_TOKEN=

# ── Splunk AI Toolkit (AITK) — PRIMARY AI ENGINE ───────────────────────────────
# The Splunk AI Toolkit exposes an OpenAI-compatible endpoint inside your Splunk
# deployment. Set both values to enable full Splunk-native AI (SPL generation,
# explanation, optimization, security investigation).
#
# How to get SPLUNK_AITK_URL:
#   Splunk Web → Apps → AI Toolkit → Settings → API Endpoint URL
#   Typically: https://<splunk-host>:8089/services/openai/v1
#
# SPLUNK_TOKEN is reused as the API key (same token from Splunk auth above).
# SPLUNK_AITK_MODEL options depend on what models are hosted in your AITK:
#   - llama3-sqlcoder-8b  (recommended for SPL)
#   - gpt-4o              (if using Splunk Hosted Models / Azure OpenAI backend)
#   - mistral-7b
SPLUNK_AITK_URL=
SPLUNK_AITK_MODEL=llama3-sqlcoder-8b

# ── Amazon Bedrock — SECONDARY AI ENGINE (optional fallback) ───────────────────
# Used if AITK is not configured. Enables Claude 3 Sonnet for AI responses.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ── App Settings ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
